	<!-- SCROLL DOWN -->
	<script type="text/javascript">

		function sleep(ms) {
			return new Promise(resolve => setTimeout(resolve, ms));
		}

		async function LoadIMGs(img_data,img_start,img_stop,img_ext,img_folder,sec) {
			await sleep(sec*1000);
			console.log("loading images... index start: " + img_start + ', index stop: ' + img_stop);
			var filename = "";

			// load thumbnails
			for( i = img_start; i < img_stop; i++){
				filename = img_data[i].file.replace(/\.[^/.]+$/, "")
				$(".img-responsive").eq(i).attr("src", img_folder + filename + img_ext)
			}
		}

		function LoadIMGsNow(img_data,img_start,img_stop,img_ext,img_folder) {
			console.log("loading images now!!! index start: " + img_start + ', index stop: ' + img_stop);
			var filename = "";

			// load thumbnails
			for( i = img_start; i < img_stop; i++){
				filename = img_data[i].file.replace(/\.[^/.]+$/, "")
				$(".img-responsive").eq(i).attr("src", img_folder + filename + img_ext)
			}
		}


		if(canUseWebP()){ // browser supporta webp
			//$("#landingHeader").css("background-image", "url('images/covers/cover1_overlay.webp')")
			LoadIMGsNow(data,0,data.length,".webp","images/small_webp/");
		}else{
			//$("#landingHeader").css("background-image", "url('images/covers/cover1_overlay.jpg')")
			LoadIMGsNow(data,0,data.length,".jpg","images/small/");
		}
		

		// set size banner to full screen, works on mobile
		// $("#landingHeader").css('height',$(window).innerHeight() + 'px');
		$("#down").css("top",$(window).innerHeight()*0.85 + 'px');

		// place arrow down at right location mobile
		$("#down").mouseover(function() {
			$(this).css("top",$(window).innerHeight()*0.87 + 'px');
		}).mouseout(function() {
			$(this).css("top",$(window).innerHeight()*0.85 + 'px');
		});

		window.onbeforeunload = function () {
			window.scrollTo(0, 0);
		}
		
		$(document).ready( function () {
			$('#down').on('click',function () {
				$("html").scrollTop(0);
				console.log("Clicked!");
				$('html, body').animate({
					scrollTop: $(".container-fluid").offset().top
				}, 700);
			});
		});

		$(window).resize(function(){
			if(!/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
				location.reload(); // reload on resize, desktop only
			}
			// $("#landingHeader").css('height',$(window).innerHeight() + 'px'); // set size banner
			// $("#down").css("top",$(window).innerHeight()*0.85 + 'px'); // set arrow at right height
		}); 


		// $(window).on('scroll resize', function() {
		// 	}).one('scroll resize', function() {
		// 		if (Math.abs(100 - $(this).scrollTop()) < 100) {
		// 		}
		// });


