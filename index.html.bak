	<!-- SCROLL DOWN -->
	<script type="text/javascript">



		var initial_load_n_imgs = 12; // has to be dividable by 3

		function sleep(ms) {
			return new Promise(resolve => setTimeout(resolve, ms));
		}

		async function LoadIMGsWithDelay(img_data,img_start,img_stop,img_ext,img_folder,sec) {
			await sleep(sec*1000);
			console.log("loading images... index start: " + img_start + ', index stop: ' + img_stop);
			var filename = "";

			// load thumbnails
			for( i = img_start; i < img_stop; i++){
				filename = img_data[i].file.replace(/\.[^/.]+$/, "")
				$(".img-responsive").eq(i).attr("src", img_folder + filename + img_ext)
				$(".image-popup").eq(i).css("opacity",1)
			}
		}

		function LoadIMGsNow(img_data,img_start,img_stop,img_ext,img_folder) {
			console.log("loading images now!!! index start: " + img_start + ', index stop: ' + img_stop);
			var filename = "";

			// load thumbnails
			for( i = img_start; i < img_stop; i++){
				filename = img_data[i].file.replace(/\.[^/.]+$/, "")
				$(".img-responsive").eq(i).attr("src", img_folder + filename + img_ext)
				$(".image-popup").eq(i).css("opacity",1)
			}

		}

		function LoadIMGSBackup() {
			if($(window).scrollTop()>1000) {
				console.log("loading images... index start: " + 0 + ', index stop: ' + data.length);
				var filename = "";
				for( i = 0; i < data.length; i++){
					filename = data[i].file.replace(/\.[^/.]+$/, "")
					$(".img-responsive").eq(i).attr("src", "images/small_webp/" + filename + ".webp")
				}
			}
		}


		if(canUseWebP()){ // browser supporta webp
			//$("#landingHeader").css("background-image", "url('images/covers/cover1_overlay.webp')")
			LoadIMGsNow(data,0,initial_load_n_imgs/3,".webp","images/small_webp/");
			LoadIMGsWithDelay(data,initial_load_n_imgs/3,(initial_load_n_imgs/3)*2,".webp","images/small_webp/",0.4);
			LoadIMGsWithDelay(data,(initial_load_n_imgs/3)*2,initial_load_n_imgs,".webp","images/small_webp/",0.8);
		}else{
			//$("#landingHeader").css("background-image", "url('images/covers/cover1_overlay.jpg')")
			LoadIMGsNow(data,0,initial_load_n_imgs,".jpg","images/small/");
			LoadIMGsWithDelay(data,initial_load_n_imgs/3,(initial_load_n_imgs/3)*2,".jpg","images/small/",0.4);
			LoadIMGsWithDelay(data,(initial_load_n_imgs/3)*2,initial_load_n_imgs,".jpg","images/small/",0.8);
		}


		$(window).on('scroll resize', function() { }).one('scroll resize', function() {
	
			if (Math.abs(100 - $(this).scrollTop()) < 1000) {
		
				// image properties, check if browser doesn't support webp
				var filename = "";
				var file_ext = ".webp";
				var folder = "images/small_webp/";
				var webp = canUseWebP();
				if(!webp) {
					file_ext = ".jpg";
					folder = "images/small/";
				}

				// loading batch settings
				var n_load_batches = 3;		
				var n_imgs_per_batch = Math.round( (data.length-initial_load_n_imgs) / n_load_batches);
				let stops = [initial_load_n_imgs]; // image to start at
				for( i = 1; i < (n_load_batches+1); i++) stops.push(initial_load_n_imgs + n_imgs_per_batch*i)
				stops[stops.length-1] = data.length
				

				// load thumbnails in batches
				var b = 0;
				LoadIMGsWithDelay(data,stops[b],stops[b+1],file_ext,folder,0); b++
				LoadIMGsWithDelay(data,stops[b],stops[b+1],file_ext,folder,1); b++		
				LoadIMGsWithDelay(data,stops[b],stops[b+1],file_ext,folder,2); b++					
				// LoadIMGsWithDelay(data,stops[b],stops[b+1],file_ext,folder,5); b++
				// LoadIMGsWithDelay(data,stops[b],stops[b+1],file_ext,folder,6); b++

			}
		});


	</script>


